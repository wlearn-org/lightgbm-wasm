{
  "name": "@wlearn/lightgbm",
  "version": "0.2.0",
  "description": "LightGBM WASM port for wlearn",
  "type": "commonjs",
  "main": "src/index.js",
  "exports": {
    ".": {
      "require": "./src/index.js",
      "default": "./src/index.js"
    }
  },
  "files": [
    "src/",
    "wasm/",
    "dist/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "node test/test.js",
    "build": "bash scripts/build-wasm.sh",
    "verify": "bash scripts/verify-exports.sh",
    "build:browser": "bash scripts/build-browser.sh",
    "prepack": "node scripts/prepack.js",
    "prepublishOnly": "node scripts/prepublish.js"
  },
  "dependencies": {
    "@wlearn/core": "0.2.0"
  },
  "keywords": [
    "lightgbm",
    "gradient-boosting",
    "machine-learning",
    "wasm",
    "webassembly",
    "wlearn"
  ],
  "author": "Anton Zemlyansky",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wlearn-org/lightgbm-wasm.git"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "playwright": "^1.58.2"
  },
  "bugs": {
    "url": "https://github.com/wlearn-org/lightgbm-wasm/issues"
  },
  "homepage": "https://wlearn.org"
}
